# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth - REQUIRED: Generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://yourdomain.com"

# Admin credentials - REQUIRED for production
# Email address for the admin account
ADMIN_EMAIL="admin@referralhub.com"
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=""

# IP anonymization salt - REQUIRED: Generate with `openssl rand -hex 16`
IP_HASH_SALT=""
