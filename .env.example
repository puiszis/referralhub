# ─────────────────────────────────────────────────────────
# DATABASE  (Railway PostgreSQL adds DATABASE_URL automatically)
# ─────────────────────────────────────────────────────────
# Railway sets this automatically when you attach a Postgres service.
# For local dev: change to file:./dev.db and switch schema.prisma provider to sqlite
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Required when using Railway PostgreSQL with connection pooling (PgBouncer)
# Set to the same value as DATABASE_URL if not using a pooler
DIRECT_URL="postgresql://user:password@host:5432/railway"

# ─────────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────────
# REQUIRED: Generate with -> openssl rand -base64 32
NEXTAUTH_SECRET=""

# Your Railway public URL (e.g. https://referralhub.up.railway.app)
# Or your custom domain once configured
NEXTAUTH_URL="https://your-app.up.railway.app"

# ─────────────────────────────────────────────────────────
# ADMIN CREDENTIALS
# ─────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@yourdomain.com"

# REQUIRED: Generate with -> npm run hash-password yourpassword
# Example: npm run hash-password "MySecurePassword123!"
ADMIN_PASSWORD_HASH=""

# ─────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────
# REQUIRED: Generate with -> openssl rand -hex 16
IP_HASH_SALT=""
